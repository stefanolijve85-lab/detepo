{
  "name": "@workspace/game-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "drizzle:generate": "drizzle-kit generate --config drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^5.0.0",
    "drizzle-orm": "^0.36.0",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5",
    "zod": "^4.0.0",
    "jose": "^5.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.16.0",
    "typescript": "~5.9.2",
    "vitest": "^2.0.0"
  }
}
