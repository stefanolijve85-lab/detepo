{
  "expo": {
    "name": "Detepo",
    "slug": "detepo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "detepo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070B14"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Detepo Insights gebruikt Bluetooth om tellers te koppelen en te configureren.",
        "NSBluetoothPeripheralUsageDescription": "Detepo Insights gebruikt Bluetooth om tellers te koppelen en te configureren."
      },
      "bundleIdentifier": "com.detepo.app"
    },
    "android": {
      "package": "com.detepo.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}