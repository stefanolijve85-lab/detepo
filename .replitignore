# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make publishing faster.

# Replit internal
.local

# Duplicate / legacy project directories (not needed for deployment)
detepo_project/
detepo-mobile/

# Large binary / archive files never needed at runtime
*.zip
*.tar
*.tar.gz
*.tgz

# Dev assets and screenshots
attached_assets/

# Git history (not needed in production image)
.git/

# Expo / React Native build caches
artifacts/mobile/.expo/
artifacts/mobile/android/
artifacts/mobile/ios/
detepo_project/artifacts/mobile/.expo/

# Test / coverage artefacts
coverage/
**/__tests__/
