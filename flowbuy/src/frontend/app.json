{
  "expo": {
    "name": "FlowBuy",
    "slug": "flowbuy",
    "scheme": "flowbuy",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.flowbuy.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FlowBuy uses your location to recommend products that match the local weather (e.g. an umbrella when it's raining)."
      }
    },
    "android": {
      "package": "app.flowbuy.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FlowBuy uses your location to recommend products that match the local weather."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:4000"
    }
  }
}
