# ---- Database ----
DATABASE_URL="postgresql://flowbuy:flowbuy_dev@localhost:5432/flowbuy?schema=public"

# ---- AI (Anthropic Claude) ----
ANTHROPIC_API_KEY="sk-ant-..."
# Default model for the orchestrator. Override to test new models.
CLAUDE_MODEL="claude-3-5-sonnet-20241022"

# ---- Weather ----
OPENWEATHER_API_KEY=""
# Optional fallback location used when no GPS is provided.
DEFAULT_LAT="52.3676"
DEFAULT_LON="4.9041"
DEFAULT_CITY="Amsterdam"

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY="sk_test_..."

# ---- Server ----
PORT="4000"
NODE_ENV="development"

# ---- Feature flags ----
# When true, the AI orchestrator runs in MOCK mode and never calls Claude.
# Useful for offline dev and CI.
USE_MOCK_AI="true"
# When true, the weather service returns deterministic mock data.
USE_MOCK_WEATHER="true"
